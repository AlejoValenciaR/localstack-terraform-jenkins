# Optional defaults for scripts/terraform_infra.sh.
# Do not put AWS credentials in this file.

AWS_REGION=us-east-1
ENABLE_EKS=false
TF_PARALLELISM=1
TF_DISABLE_BACKEND=false

# Terraform variables
ECR_REPOSITORY_NAME=hello-spring
VPC_CIDR=10.0.0.0/16
SUBNET_1_CIDR=10.0.1.0/24
SUBNET_2_CIDR=10.0.2.0/24
EKS_CLUSTER_NAME=localstack-eks-cluster
EKS_NODE_GROUP_NAME=localstack-eks-node-group
EKS_NODE_INSTANCE_TYPES=t3.medium
EKS_NODE_DESIRED_SIZE=1
EKS_NODE_MIN_SIZE=1
EKS_NODE_MAX_SIZE=2

# AzureRM backend defaults (used when TF_DISABLE_BACKEND=false)
TFSTATE_STORAGE_ACCOUNT=alejatfstate2026demo
TFSTATE_CONTAINER=tfstate
TFSTATE_KEY=localstack-terraform-jenkins.tfstate
# TFSTATE_RESOURCE_GROUP must come from Jenkins credential or env var.
