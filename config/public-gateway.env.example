# Optional defaults for scripts/public_k8s_gateway_routes.sh.
# This script updates the public nginx gateway on the Azure VM.

PUBLIC_GATEWAY_ACCESS_MODE=ssh
PUBLIC_GATEWAY_SERVER_NAME=nauthappstest.tech
PUBLIC_GATEWAY_REMOTE_HOST=68.155.156.136
PUBLIC_GATEWAY_REMOTE_PORT=22
PUBLIC_GATEWAY_REMOTE_USER=azureuser

# Leave blank to auto-detect the nginx site config file that contains the server_name.
PUBLIC_GATEWAY_SITE_CONFIG=

# The nginx include file written by the sync script.
PUBLIC_GATEWAY_INCLUDE_DIR=/etc/nginx/nauthapps.d
PUBLIC_GATEWAY_INCLUDE_FILE=/etc/nginx/nauthapps.d/public-k8s-routes.conf

# Requests for these branded paths are proxied to the k3d ingress listener.
PUBLIC_K8S_UPSTREAM=http://127.0.0.1:8081
PUBLIC_K8S_ROUTES_FILE=
