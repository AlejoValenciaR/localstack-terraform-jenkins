# Optional local defaults for scripts/localstack_infra.sh.
# Do not put AWS credentials in this file.

AWS_REGION=us-east-1

ECR_REPOSITORY_NAME=hello-spring

VPC_NAME=localstack-main-vpc
VPC_CIDR=10.0.0.0/16

SUBNET_A_NAME=localstack-subnet-a
SUBNET_B_NAME=localstack-subnet-b
SUBNET_A_CIDR=10.0.1.0/24
SUBNET_B_CIDR=10.0.2.0/24
SUBNET_A_AZ=us-east-1a
SUBNET_B_AZ=us-east-1b

ENABLE_EKS=false
EKS_CLUSTER_NAME=localstack-eks-cluster
EKS_NODE_GROUP_NAME=localstack-eks-node-group
EKS_NODE_INSTANCE_TYPE=t3.medium
EKS_NODE_DESIRED_SIZE=1
EKS_NODE_MIN_SIZE=1
EKS_NODE_MAX_SIZE=2
